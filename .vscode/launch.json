{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CTest (GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${cmake.testProgram}",
      "args": "${cmake.testArgs}",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "environment": [
        {
          "name": "SUN_PATH",
          "value": "${workspaceFolder}"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set disassembly flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      "showDisplayString": true
    },
    {
      "name": "Debug CTest (LLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${cmake.testProgram}",
      "args": [
        "${cmake.testArgs}"
      ],
      "cwd": "${cmake.testWorkingDirectory}",
      "stopOnEntry": false,
      "initCommands": [
        "settings set target.x86-disassembly-flavor intel"
      ],
    },
    {
      "name": "Debug Script",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/sun",
      "args": [
        "test.sun"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "CMake: build"
    },
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode-sun"
      ],
      "outFiles": [
        "${workspaceFolder}/extensions/vscode-sun/out/**/*.js"
      ],
      "preLaunchTask": "sun-extension: compile"
    }
  ]
}