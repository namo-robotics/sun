{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CTest (LLDB-DAP)",
      "type": "lldb-dap",
      "request": "launch",
      "program": "${cmake.testProgram}",
      "args": [
        "${cmake.testArgs}"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "SUN_PATH": "${workspaceFolder}"
      },
      // === LLDB-specific settings ===
      "initCommands": [
        "settings set target.load-cwd-lldbinit true",
        "settings set disassembly-flavor intel",
        "settings set target.prefer-dynamic-value no-dynamic-values",
        "settings set target.skip-prologue true",
        "settings set target.disable-aslr false",
        "settings set target.max-children-count 20",
        "settings set target.max-string-summary-length 128",
        "settings set target.max-memory-read-size 1024"
      ],
      "preRunCommands": [
        "settings set target.process.thread.step-in-avoid-nodebug true",
        "settings set target.process.thread.step-out-avoid-nodebug true"
      ],
      // === Critical fix for containers ===
      "disableASLR": false,
      "disableSTDIO": false,
      // Stability for large LLVM/C++ projects
      "timeout": 60,
      "enableAutoVariableSummaries": false,
      "enableSyntheticChildDebugging": false,
    },
    {
      "name": "Debug CTest (LLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${cmake.testProgram}",
      "args": [
        "${cmake.testArgs}"
      ],
      "cwd": "${cmake.testWorkingDirectory}",
      "stopOnEntry": false,
      "initCommands": [
        "settings set target.x86-disassembly-flavor intel"
      ],
    },
    {
      "name": "Debug Script",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/sun",
      "args": [
        "test.sun"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "CMake: build"
    },
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode-sun"
      ],
      "outFiles": [
        "${workspaceFolder}/extensions/vscode-sun/out/**/*.js"
      ],
      "preLaunchTask": "sun-extension: compile"
    }
  ]
}