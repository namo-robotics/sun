{
    // === CMake + Build ===
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,
    // === IntelliSense (clangd) ===
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.default.configurationProvider": "",
    "clangd.arguments": [
        "--background-index",
        "--compile-commands-dir=${workspaceFolder}/build",
        "--header-insertion=iwyu",
        "--all-scopes-completion",
        "--completion-style=detailed"
    ],
    // === Formatting ===
    "C_Cpp.formatting": "clangFormat",
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.clang_format_fallbackStyle": "Google",
    "editor.formatOnSave": true,
    "[cpp]": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": false
    },
    "[plaintext]": {
        "editor.formatOnSave": false
    },
    "[makefile]": {
        "editor.formatOnSave": false
    },
    // === Editor UI ===
    "editor.rulers": [
        80,
        120
    ],
    "testMate.cpp.test.stderrDecorator": true,
    "testMate.cpp.log.logpanel": true,
    "testMate.cpp.test.workingDirectory": "${workspaceFolder}",
    "files.associations": {
        "debian/rules": "makefile",
        "debian/control": "plaintext",
        "debian/copyright": "plaintext",
        "debian/changelog": "plaintext",
        "debian/source/format": "plaintext",
        "debian/install": "plaintext",
        "*.proto": "proto"
    },
    // === Project-Specific ===
    "sun.sunPath": [
        "build",
        "/workspaces/sun"
    ],
    "sun.lsp.path": "build/sun-lsp",
    // === LLDB (for debugging) ===
    "lldb-dap.executable-path": "/usr/lib/llvm-20/bin/lldb-dap",
}